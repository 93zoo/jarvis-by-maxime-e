{
  "expo": {
    "name": "JARVIS BY Maxime-E",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#04080f"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "JARVIS a besoin du microphone pour entendre vos commandes vocales."
      }
    },
    "android": {
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0099FF",
          "androidMode": "default",
          "androidCollapsedTitle": "JARVIS"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "JARVIS a besoin de votre position pour la navigation GPS.",
          "locationAlwaysAndWhenInUsePermission": "JARVIS a besoin de votre position pour la navigation GPS."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
