{
  "expo": {
    "name": "JARVIS BY Maxime-E",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#04080f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maximeetivant.jarvisai",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "JARVIS a besoin du microphone pour entendre vos commandes vocales.",
        "NSContactsUsageDescription": "JARVIS accède à vos contacts pour passer des appels et envoyer des SMS."
      }
    },
    "android": {
      "package": "com.maximeetivant.jarvisai",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#04080f"
      },
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE",
        "READ_CONTACTS",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0099FF",
          "androidMode": "default",
          "androidCollapsedTitle": "JARVIS"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "JARVIS a besoin de votre position pour la navigation GPS.",
          "locationAlwaysAndWhenInUsePermission": "JARVIS a besoin de votre position pour la navigation GPS."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "JARVIS a besoin du microphone pour les commandes vocales."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
